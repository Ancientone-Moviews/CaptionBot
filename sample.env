# Telegram API credentials (get from https://my.telegram.org)
API_ID=0
API_HASH=your_api_hash_here

# Bot token (get from @BotFather)
BOT_TOKEN=123456:ABC-YourBotTokenHere

# Your Telegram user ID (get from @userinfobot)
ADMIN_ID=0

# Comma-separated channel IDs the bot should monitor
ALLOWED_CHATS=-100xxxxxxxxxx

# MongoDB connection string (get from https://cloud.mongodb.com)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=mediainfo_bot

# GitHub repo URL for auto-update on /restart (leave empty to disable)
UPSTREAM_REPO=https://github.com/user/MediaInfo-Bot
UPSTREAM_BRANCH=main

# Space-separated list of helper bot tokens (optional, used to distribute API limits)
# e.g. 1111:AAAA 2222:BBBB
HELPER_TOKENS=
